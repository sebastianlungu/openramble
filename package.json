{
  "name": "open-ramble",
  "version": "0.1.0",
  "type": "module",
  "description": "Zero-friction multimodal intent compiler for coding agents",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "bin": {
    "open-ramble": "./src/index.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.16.2"
  },
  "scripts": {
    "open-ramble": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bunx oxlint .",
    "lint:fix": "bunx oxlint --fix .",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test",
    "proof": "bun run src/opencode-bridge/proof.ts",
    "start": "bun run src/index.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.9"
  }
}
